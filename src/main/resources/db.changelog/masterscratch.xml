<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="create-table_race" author="Leonid Velikanov">
        <preConditions>
            <not>
                <tableExists tableName="race"/>
            </not>
        </preConditions>
        <createTable tableName="race">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <insert tableName="race">
            <column name="name" value="HUMAN"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="DWARF"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="ELF"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="GIANT"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="ORC"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="TROLL"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="HOBBIT"/>
        </insert>
    </changeSet>
    <changeSet id="create-table-profession" author="Leonid Velikanov">
        <preConditions>
            <not>
                <tableExists tableName="profession"/>
            </not>
        </preConditions>
        <createTable tableName="profession">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <insert tableName="profession">
            <column name="name" value="WARRIOR"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="ROGUE"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="SORCERER"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="CLERIC"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="PALADIN"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="NAZGUL"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="WARLOCK"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="DRUID"/>
        </insert>

    </changeSet>
    <changeSet id="create-table-player" author="Leonid Velikanov">
        <preConditions>
            <not>
                <tableExists tableName="player"/>
            </not>
        </preConditions>
        <createTable tableName="player">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(12)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="race_id" type="int">
                <constraints nullable="false" foreignKeyName="race_id" references="race(id)"/>
            </column>
            <column name="profession_id" type="int">
                <constraints nullable="false" foreignKeyName="profession_id" references="profession(id)"/>
            </column>
            <column name="experience" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="until_next_level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="birthday" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="banned" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="change-player-id-to-bigint-h2" author="Leonid Velikanov" dbms="h2">
        <dropPrimaryKey tableName="player"/>
        <modifyDataType tableName="player" columnName="id" newDataType="bigint"/>
        <addAutoIncrement tableName="player" columnName="id" columnDataType="bigint"/>
        <addPrimaryKey tableName="player" constraintName="pk_player" columnNames="id"/>
        <addNotNullConstraint tableName="player" columnName="id" constraintName="player_id_not_null"/>
    </changeSet>

    <changeSet id="change-player-id-to-bigint-pg" author="Leonid Velikanov" dbms="postgresql">
        <dropPrimaryKey tableName="player"/>
        <modifyDataType tableName="player" columnName="id" newDataType="bigint"/>
        <addPrimaryKey tableName="player" constraintName="pk_player" columnNames="id"/>
        <addNotNullConstraint tableName="player" columnName="id" constraintName="player_id_not_null"/>
    </changeSet>

    <changeSet id="change-race-id-to-bigint-h2" author="Leonid Velikanov" dbms="h2">
        <dropForeignKeyConstraint baseTableName="player" constraintName="race_id"/>
        <dropPrimaryKey tableName="race"/>
        <modifyDataType tableName="race" columnName="id" newDataType="bigint"/>
        <addAutoIncrement tableName="race" columnName="id" columnDataType="bigint"/>
        <addPrimaryKey tableName="race" constraintName="pk_race" columnNames="id"/>
        <addForeignKeyConstraint baseTableName="player" baseColumnNames="race_id" constraintName="race_id" referencedTableName="race" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="change-race-id-to-bigint-pg" author="Leonid Velikanov" dbms="postgresql">
        <dropForeignKeyConstraint baseTableName="player" constraintName="race_id"/>
        <dropPrimaryKey tableName="race"/>
        <modifyDataType tableName="race" columnName="id" newDataType="bigint"/>
        <addPrimaryKey tableName="race" constraintName="pk_race" columnNames="id"/>
        <addForeignKeyConstraint baseTableName="player" baseColumnNames="race_id" constraintName="race_id" referencedTableName="race" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="change-profession-id-to-bigint-h2" author="Leonid Velikanov" dbms="h2">
        <dropForeignKeyConstraint baseTableName="player" constraintName="profession_id"/>
        <dropPrimaryKey tableName="profession"/>
        <modifyDataType tableName="profession" columnName="id" newDataType="bigint"/>
        <addAutoIncrement tableName="profession" columnName="id" columnDataType="bigint"/>
        <addPrimaryKey tableName="profession" constraintName="pk_profession" columnNames="id"/>
        <addForeignKeyConstraint baseTableName="player" baseColumnNames="profession_id" constraintName="profession_id" referencedTableName="profession" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="change-profession-id-to-bigint-pg" author="Leonid Velikanov" dbms="postgresql">
        <dropForeignKeyConstraint baseTableName="player" constraintName="profession_id"/>
        <dropPrimaryKey tableName="profession"/>
        <modifyDataType tableName="profession" columnName="id" newDataType="bigint"/>
        <addPrimaryKey tableName="profession" constraintName="pk_profession" columnNames="id"/>
        <addForeignKeyConstraint baseTableName="player" baseColumnNames="profession_id" constraintName="profession_id" referencedTableName="profession" referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>