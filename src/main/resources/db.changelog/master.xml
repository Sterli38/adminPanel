<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="create-table_race" author="Leonid Velikanov">
        <preConditions>
            <not>
                <tableExists tableName="race"/>
            </not>
        </preConditions>
        <createTable tableName="race">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <insert tableName="race">
            <column name="name" value="HUMAN"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="DWARF"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="ELF"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="GIANT"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="ORC"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="TROLL"/>
        </insert>
        <insert tableName="race">
            <column name="name" value="HOBBIT"/>
        </insert>
    </changeSet>
    <changeSet id="create-table-profession" author="Leonid Velikanov">
        <preConditions>
            <not>
                <tableExists tableName="profession"/>
            </not>
        </preConditions>
        <createTable tableName="profession">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <insert tableName="profession">
            <column name="name" value="WARRIOR"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="ROGUE"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="SORCERER"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="CLERIC"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="PALADIN"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="NAZGUL"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="WARLOCK"/>
        </insert>
        <insert tableName="profession">
            <column name="name" value="DRUID"/>
        </insert>

    </changeSet>
    <changeSet id="create-table-player" author="Leonid Velikanov">
        <preConditions>
            <not>
                <tableExists tableName="player"/>
            </not>
        </preConditions>
        <createTable tableName="player">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(12)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="race_id" type="int">
                <constraints nullable="false" foreignKeyName="race_id" references="race(id)"/>
            </column>
            <column name="profession_id" type="int">
                <constraints nullable="false" foreignKeyName="profession_id" references="profession(id)"/>
            </column>
            <column name="experience" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="until_next_level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="birthday" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="banned" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>